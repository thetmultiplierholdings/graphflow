{
  "name": "@multiplier/graphflow-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "exports": {
    ".": {
      "types": "./out-tsc/index.d.ts",
      "import": "./out-tsc/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node out-tsc/index.js",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc -b --noEmit tsconfig.json",
    "lint": "biome check . --max-diagnostics=50 --error-on-warnings",
    "lint:fix": "biome check . --write",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:workflows": "tsx scripts/check-workflows.ts",
    "cli": "tsx src/cli/Cli.ts",
    "seed": "tsx src/cli/Cli.ts seed",
    "worker": "tsx src/cli/Cli.ts worker",
    "knip": "knip",
    "check": "npm run typecheck && npm run test && npm run lint && npm run check:workflows"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/multipart": "^10.1.0",
    "@noble/hashes": "^2.2.0",
    "@temporalio/activity": "^1.20.3",
    "@temporalio/client": "^1.20.3",
    "@temporalio/common": "^1.20.3",
    "@temporalio/worker": "^1.20.3",
    "@temporalio/workflow": "^1.20.3",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^7.0.0",
    "pino": "^10.1.0",
    "tslib": "^2.8.1",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.17.1",
    "@vitest/coverage-v8": "^4.1.0",
    "knip": "^5.44.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "ultracite": "7.0.11",
    "vitest": "^4.1.0"
  },
  "allowScripts": {
    "@swc/core@1.15.43": true,
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true,
    "protobufjs@7.6.5": true
  }
}
