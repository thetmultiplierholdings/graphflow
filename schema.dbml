// graphflow SQLite schema, transcribed as-is from the SCHEMA constant in
// backend/src/infrastructure/db/Db.ts (the source of truth — keep in sync by hand, in the same
// change as any schema edit). Renders on dbdiagram.io.
//
// Conventions:
//   - SQLite type affinities kept verbatim (integer / text); timestamps are ISO-8601 TEXT with
//     a +00:00 suffix at seconds precision (nowIso in Db.ts) — lexicographic order == time order.
//   - executor / source columns are TEXT with CHECK constraints in SQLite; modeled as enums here.
//   - LEDGER tables (artifacts, node_runs, node_run_inputs) are insert-only; the mutable ledger
//     columns are artifacts.label and its updated_by/updated_at stamps. WORKSPACE rows are
//     editable; deleting a workflow_run_artifacts row (detach) is the only user-facing DELETE —
//     the other DELETEs are the publish transaction rewriting the workflow_kinds and
//     node_input_kinds mirrors.
//   - HYGIENE BLOCK, tiered per table role:
//       . entity tables (engagements, artifacts, workflow_runs): created_by/created_at NOT NULL +
//         nullable updated_by/updated_at/deleted_at;
//       . node_runs (insert-only memo ledger): created_by/created_at only;
//       . workflow_run_artifacts (membership): created_* + updated_* (promotion), no deleted_at —
//         detach is a hard DELETE, membership is a fact, not an entity;
//       . catalog masters (workflows, kinds, nodes): created_at + updated_at only — the publisher
//         is always the code registry, so no actor columns; retirement = absence from the registry,
//         so no deleted_at;
//       . EXEMPT: meta (k/v singleton), workflow_kinds + node_input_kinds (publish mirrors,
//         rewritten wholesale), node_run_inputs (edges of an immutable parent).
//     Semantics: created_* is the FIRST filer — convergence (ON CONFLICT DO NOTHING) never
//     re-dates it; updated_* is NULL until first updated — the idempotent paths (promote upsert,
//     publish upserts) are guarded so a no-op never stamps, while the request-driven UPDATEs
//     (rename, workspace PATCH/archive) stamp per request, so resubmitting an identical value
//     re-stamps; deleted_at is DORMANT — always NULL, no reader filters on it,
//     reserved for a future soft delete. Known trap for that future: a soft-deleted artifact row
//     would still block re-supplying identical bytes (the DO-NOTHING conflict lands on the
//     tombstoned row), so implementing delete means deciding revive-vs-hide first.
//   - ACTOR columns (created_by/updated_by) hold principals '<type>[:<name>]', type one of
//     user | engine | system | agent (domain/principal/Principal.ts, asserted at every Db write
//     boundary). Bare 'user' = the anonymous caller; names are caller-asserted — no auth exists
//     (standing invariant), so the column is an audit trail, not an authorization record.
//   - Every FK is a plain immediate FK, enforced because every connection sets
//     PRAGMA foreign_keys=ON (connect in Db.ts). There are no deferred or circular FKs: a
//     node_runs row is inserted after its output artifact, and SQLite assigns node_run_id.
//   - No migrations yet (greenfield): initDb is CREATE IF NOT EXISTS only; schema changes ship
//     as a reset (npm run seed -- --fresh). This change REQUIRES that reset: booting new code
//     against a pre-hygiene db fails loud in publishCatalog on the missing columns.

Project graphflow {
  database_type: 'SQLite'
  Note: '''
  Content-addressed computation ledger + editable workspaces + a CI-published catalog mirror.
  SQLite is single-writer; every application write transaction uses BEGIN IMMEDIATE (initDb's
  one-time DDL and instance_id insert run in autocommit).

  READ MODEL (not a table): artifact_facts — a view over artifacts JOIN kinds adding two DERIVED
  columns served on the wire: produced_by_node_run := MIN(node_run_id) over
  node_runs.output_artifact_id (several runs can converge on one artifact via the completion
  transaction's ON CONFLICT DO NOTHING; the earliest run wins), and origin := 'produced' when a
  producing run exists, else 'override' for a hand-supplied computed kind, else the kind's
  authored source. Read models (getArtifact, browseArtifacts, workspaceArtifacts, the API
  serializers) read the view; the memo and write path (memoLookup, recordCompletion,
  supplyArtifact) stays on base tables. Provenance is derived, never stored — nothing can
  diverge from lineage.
  '''
}

// TEXT CHECK (executor IN (engine, human)) in SQLite
enum node_executor {
  engine
  human
}

// TEXT CHECK (source IN (user, engine)) in SQLite
enum attachment_source {
  user
  engine
}

// TEXT CHECK (source IN (upload, questionnaire, email, computed)) in SQLite. The channel data
// of this kind enters through: upload/questionnaire/email are LEAF channels (supplied by users; email
// is declared but has no channel behind it yet); computed kinds are produced by nodes.
// Leaf-NESS itself is never stored: it is derived per workflow (no node of the workflow produces
// the kind — catalogSnapshot in Db.ts) and reconciled against this authored channel at publish
// (validateCatalog in Registry.ts). NOT NULL is deliberate: SQLite CHECKs pass on NULL.
enum kind_source {
  upload
  questionnaire
  email
  computed
}

Table meta {
  key text [pk]
  value text [not null]
  Note: 'Key/value store; single key today: instance_id (random hex minted by initDb), which prefixes every Temporal workflow id so a shared namespace stays partitioned per database.'
}

Table engagements {
  engagement_id integer [pk]
  label text [not null]
  created_by text [not null]
  created_at text [not null]
  updated_by text [note: 'writer-less today: no engagement PATCH exists, so updated_* stays NULL (tier-uniform column, not a promise of behavior)']
  updated_at text
  deleted_at text [note: 'dormant (see Conventions)']
  Note: 'Isolation and identity scope: artifact identity and memo lookups are engagement-scoped. The reuse boundary AND the confidentiality boundary — one boundary, on purpose.'
}

// ---------- CATALOG (mirror of the in-code registry, republished by publishCatalog on every
// boot/init after validateCatalog passes. kinds/workflows/nodes are upsert-only — retired rows
// persist as FK parents, and executing a workspace pinned to a retired workflow fails loud —
// the run starts, then GraphflowRun throws non-retryable "not registered on this worker"
// (Workflows.ts) — instead of vanishing — while workflow_kinds and node_input_kinds are rewritten
// delete-then-insert inside the publish transaction, so declarations removed from code stop
// lingering.) ----------

Table kinds {
  kind text [pk]
  source kind_source [not null]
  display_name text [note: 'empty string when the declaration has no display; catalogSnapshot falls back to the kind string']
  created_at text [not null, note: 'first publish']
  updated_at text [note: 'last real change to THIS row\'s columns (source/display — guarded upsert); NULL until one; identical republish on worker restart does not bump it']
  Note: 'The instance-wide kind vocabulary — a first-class business object and the FK parent of artifacts.kind, nodes.output_kind, workflow_kinds.kind, and node_input_kinds.kind. supplyArtifact rejects kinds absent from this table BEFORE writing any payload bytes. Supplying a computed kind stays legal and derives origin=override (hand-staging a corrected intermediate is supported). Cross-workflow consistency (one kind = one source + display) is a publish error, not first-wins.'
}

Table workflows {
  workflow_id text [pk, note: '== the folder name under backend/src/workflows/ (enforced by npm run check:workflows)']
  display_name text [not null]
  created_at text [not null, note: 'first publish']
  updated_at text [note: 'last real change to THIS row\'s columns, i.e. display_name (guarded upsert) — node/kind edits bump their own rows, not this; served on /catalog, git stays the full audit trail']
  Note: 'Catalog row per authored workflow version — identity + display ONLY. Dispatch metadata lives nowhere in the db: every run starts as the RUN_WORKFLOW_TYPE constant on the env task queue (startWorkspace in Runtime.ts), so run and recovery sweeps agree by construction. The DAG itself is code (the workflow folder\'s run()).'
}

Table workflow_kinds {
  workflow_id text [not null, ref: > workflows.workflow_id]
  kind text [not null, ref: > kinds.kind]
  indexes {
    (workflow_id, kind) [pk]
  }
  Note: 'Pure membership: which kinds a workflow declares (drives the ctx.attached() gating via RunInput.declared_kinds, and the attach dialog). Rewritten delete-then-insert at publish; rowid order is declaration order (each enums.ts KINDS array).'
}

Table nodes {
  workflow_id text [not null, ref: > workflows.workflow_id]
  node_id text [not null, note: 'THE version identity: the memo key is sha256(node_id \':\' input_hash), so renaming a node opens a new question universe. Behavior change ⇒ rename (the naming contract); there is no code hash.']
  executor node_executor [not null]
  output_kind text [not null, ref: > kinds.kind]
  display_name text
  created_at text [not null, note: 'first publish']
  updated_at text [note: 'last real change to THIS row\'s columns (executor/output_kind/display — guarded upsert; an inputKinds change moves only the node_input_kinds mirror and bumps nothing); db-only, not served']
  indexes {
    (workflow_id, node_id) [pk]
  }
  Note: 'Catalog mirror and FK anchor for node_runs. Not routing config: node implementations are compiled into the worker and resolved from the registry by (workflow_id, node_id). Upsert-only: renamed nodes leave their old rows behind (accepted: those rows keep counting as producers in the derived leaf until a reset). Publish validation: a computed kind must have a producing node or be declared intake; a leaf-channel kind must have no producer; one node_id must declare one shape across all workflows.'
}

Table node_input_kinds {
  workflow_id text [not null]
  node_id text [not null]
  param text [not null, note: 'the parameter name — also a hashed key inside the canonical argument map']
  kind text [ref: > kinds.kind, note: 'NULL = scalar argument (no artifact kind)']
  indexes {
    (workflow_id, node_id, param) [pk]
  }
  Note: 'The declared input ports: defineNode\'s inputKinds map IS the parameter declaration (params list and paramNames are derived from its keys). Rewritten delete-then-insert at publish; rowid order is declaration order. Enforced at run time in Ctx.node before anything is hashed (enforceInputKinds in Context.ts). Serves the catalog\'s input_kinds wire field — enough to render the dataflow graph without executing it. Deliberately excluded from memo keys and artifact identity.'
}

Ref: node_input_kinds.(workflow_id, node_id) > nodes.(workflow_id, node_id)

// ---------- LEDGER (insert-only facts) ----------

Table artifacts {
  artifact_id integer [pk]
  engagement_id integer [not null, ref: > engagements.engagement_id]
  hash text [not null, note: 'sha256 hex of the payload bytes — content identity, no provenance']
  kind text [not null, ref: > kinds.kind]
  label text [note: 'the one content-facing mutable ledger column (renameArtifact) — every rename stamps updated_*']
  media_type text [not null]
  byte_size integer [not null]
  payload_ref text [note: 'content-addressed write-once location {engagement_id}/{hash} under the storage root; NULL = payload destroyed per policy (content route serves 410) — payload destruction is a policy action on the blob, NOT a row deletion (deleted_at stays orthogonal)']
  created_by text [not null, note: 'the FIRST filer principal — the reviewer name on a human answer lives here; convergence keeps it']
  created_at text [not null]
  updated_by text [note: 'rename is the only writer today']
  updated_at text
  deleted_at text [note: 'dormant (see Conventions, incl. the re-supply trap)']
  indexes {
    (engagement_id, kind, hash) [unique]
    (engagement_id, kind, created_at) [name: 'idx_browse']
  }
  Note: 'Values. Identity = (engagement_id, kind, payload hash): identical bytes under one kind converge to one row, so different questions can share one answer and re-uploads revive prior work. There is NO producer column — produced_by_node_run and origin are derived by the artifact_facts view (see the project note).'
}

Table node_runs {
  node_run_id integer [pk, note: 'assigned by SQLite (plain INTEGER PRIMARY KEY)']
  engagement_id integer [not null, ref: > engagements.engagement_id]
  workflow_id text [not null]
  node_id text [not null]
  memo_key text [not null, note: 'sha256(node_id \':\' sha256(canonical argument map)) — minted sandbox-side in Ctx.node; artifact args hash as {$artifact: <content hash>}']
  output_artifact_id integer [not null, ref: > artifacts.artifact_id, note: 'plain immediate FK — the artifact row is always inserted first']
  temporal_id text [not null, note: 'engine rows: workflowId/runId/activityId; human rows: workflowId/runId']
  created_by text [not null, note: 'same principal as the output artifact it files']
  created_at text [not null, note: 'the completion tx files artifact + node_run + attach under ONE shared stamp (filedAt in recordCompletion)']
  indexes {
    (engagement_id, memo_key) [unique]
    output_artifact_id [name: 'idx_reverse_lineage']
  }
  Note: 'The memo / constructive-trace store: one row per DISTINCT answered question, not per execution — memo hits insert nothing here (they only add a workspace membership row), and run-button presses are not recorded in the db at all. UNIQUE (engagement_id, memo_key) is the final race tiebreak in recordCompletion.'
}

Ref: node_runs.(workflow_id, node_id) > nodes.(workflow_id, node_id)

Table node_run_inputs {
  node_run_id integer [not null, ref: > node_runs.node_run_id]
  artifact_id integer [not null, ref: > artifacts.artifact_id]
  indexes {
    (node_run_id, artifact_id) [pk]
    artifact_id [name: 'idx_consumer']
  }
  Note: 'Provenance edges: which artifacts each computation consumed. Recorded as rows, deliberately excluded from identity (no Merkle recursion — history never enters a hash).'
}

// ---------- WORKSPACE (editable business layer; "workspace" in code and API) ----------

Table workflow_runs {
  workflow_run_id integer [pk]
  engagement_id integer [not null, ref: > engagements.engagement_id]
  workflow_id text [not null, ref: > workflows.workflow_id]
  label text [not null]
  copied_from_workflow_run integer [ref: > workflow_runs.workflow_run_id, note: 'copy provenance; a copy carries only user-sourced attachments']
  archived_at text [note: 'reversible domain flag (archive/unarchive), deliberately separate from the hygiene block; toggling it stamps updated_*']
  created_by text [not null]
  created_at text [not null]
  updated_by text [note: 'stamped by PATCH and archive/unarchive; PATCH {} is a no-op and stamps nothing']
  updated_at text
  deleted_at text [note: 'dormant (see Conventions)']
  indexes {
    (engagement_id, created_at) [name: 'idx_workspaces']
  }
  Note: 'A workspace (named input set + results pinboard), NOT an execution record — executions live only in Temporal, and the per-run Summary is never written to the db. Also the run-mutex scope: the Temporal workflow id is wfrun-{instance}-{workflow_run_id}.'
}

Table workflow_run_artifacts {
  workflow_run_id integer [not null, ref: > workflow_runs.workflow_run_id]
  artifact_id integer [not null, ref: > artifacts.artifact_id]
  source attachment_source [not null, note: 'user = run input (part of the snapshot); engine = result pinned by a run. Workspace membership provenance — a separate concept from the derived artifact origin.']
  created_by text [not null, note: 'who FIRST attached — served on the wire under the member-scoped aliases added_by/added_at (the joined row also carries the artifact\'s own created_*, so the names must differ there)']
  created_at text [not null, note: 'members list in first-attach order (MEMBERS_SQL)']
  updated_by text [note: 'the promoter — set only by a real engine→user promotion (guarded upsert); db-only, the wire signals promotion via source']
  updated_at text
  indexes {
    (workflow_run_id, artifact_id) [pk]
    artifact_id [name: 'idx_impact']
  }
  Note: 'Workspace membership. User attach PROMOTES an engine row to user (source flips, updated_* records the promoter, created_* — first attacher and time — survives, and the member keeps its list position); engine attach never demotes (ON CONFLICT DO NOTHING); a user→user re-attach is a true no-op (the promote upsert\'s WHERE source=engine guard). Detach (DELETE) removes membership, never the artifact — reintroducing the same bytes revives all prior work. No deleted_at: detach is the delete.'
}

TableGroup catalog {
  kinds
  workflows
  workflow_kinds
  nodes
  node_input_kinds
}

TableGroup ledger {
  artifacts
  node_runs
  node_run_inputs
}

TableGroup workspace {
  workflow_runs
  workflow_run_artifacts
}
