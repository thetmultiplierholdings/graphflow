    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitest/coverage-v8": "^4.1.0",
    "cleanstring-ts": "^1.1.7",
    "command-line-args": "^6.0.1",
    "concurrently": "^9.2.0",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.31.0",
