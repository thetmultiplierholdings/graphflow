{
  "name": "multiplier",
  "packageManager": "yarn@4.9.2",
  "type": "module",
  "engines": {
    "node": "22.19.0"
  },
  "workspaces": [
    "apps/*",
    "libs/**/*"
  ],
  "scripts": {
    "app:cli": "INVOKING_CWD=\"$PWD\" yarn workspace @multiplier/platform-cli",
    "app:corporate:api": "yarn workspace @multiplier/corporate-api",
    "app:corporate:dataservice": "yarn workspace @multiplier/corporate-dataservice",
    "app:components": "yarn workspace @multiplier/platform-component-browser",
    "app:corporate:frontend": "yarn workspace @multiplier/corporate-frontend",
    "app:dashboard": "yarn workspace @multiplier/platform-dashboard",
    "app:internal-notifier": "yarn workspace @multiplier/internal-notifier",
    "app:platform": "yarn workspace @multiplier/platform-service",
    "app:tax:api": "yarn workspace @multiplier/tax-api",
    "app:tax:dataservice": "yarn workspace @multiplier/tax-dataservice",
    "app:tax:frontend": "yarn workspace @multiplier/tax-frontend",
    "app:workflows": "yarn workspace @multiplier/platform-workflows",
    "app:webhooks": "yarn workspace @multiplier/platform-webhooks",
    "ai-pentest": "yarn exec tsx scripts/ai-pentest/Run.ts",
    "ai-pentest:local": "yarn exec tsx scripts/ai-pentest/Run.ts --mode=local",
    "build": "nx run-many --target build --nxBail",
    "ci": "yarn ci:shared && yarn nx affected -t typecheck build test build:publish --nxBail",
    "ci:shared": "yarn constraints && yarn check:locale-codes && yarn nx sync:check && yarn lint",
    "ci:frontend": "yarn ci:shared && yarn nx affected -t typecheck build test --exclude='*,!tag:type:frontend' --nxBail",
    "ci:backend": "yarn ci:shared && yarn nx affected -t typecheck build test build:publish bundle:prod --exclude=tag:type:frontend --nxBail",
    "ci:all": "yarn ci:shared && yarn nx run-many -t typecheck build test build:publish --nxBail",
    "ci:fix": "yarn constraints --fix && yarn generate:locale-codes && yarn nx sync && yarn validate && yarn lint:fix && yarn nx affected -t typecheck build test build:publish --nxBail",
    "check": "yarn validate && yarn nx affected -t lint typecheck test build:publish --nxBail",
    "check:llm": "./scripts/llm-check/check-llm.sh",
    "check:no-bq": "yarn nx affected -t lint typecheck test build:publish --exclude=tag:requires:bigquery-emulator --nxBail",
    "check:all": "yarn nx run-many -t lint typecheck test build:publish --nxBail",
    "check:watch": "yarn nx watch --all --includeDependentProjects -- nx run-many --target lint typecheck build test --projects \\$NX_PROJECT_NAME",
    "clean": "yarn nx reset && rm -rf .yarn/install-state.gz ./node_modules && find . -type d \\( -name 'dist' -o -name 'out-tsc' -o -name 'node_modules' \\) -prune -exec rm -rf {} +",
    "constraints": "yarn constraints",
    "constraints:fix": "yarn constraints --fix",
    "dev:dependencies": "yarn install && yarn build && yarn run dev:dependencies:services && yarn run dev:dependencies:migrate",
    "dev:dependencies:services": "./infra/local/start-services.sh --background",
    "dev:dependencies:migrate": "yarn run lib:organization-management db:migrate && yarn run app:platform db:migrate",
    "format": "yarn exec biome format --write .",
    "format:check": "yarn exec biome format .",
    "generate:agents": "./scripts/generate-agents-md.sh",
    "generate:dashboards": "./scripts/generate-dashboards.sh",
    "check:dashboards": "./scripts/generate-dashboards.sh --check",
    "generate:locale-codes": "yarn exec tsx scripts/generate-locale-codes.ts",
    "check:locale-codes": "yarn generate:locale-codes && git diff --exit-code libs/shared/cldr-data/src/generated/LocaleCodes.ts",
    "generate:specs": "yarn nx run-many -t generate-workflow-schemas generate-openapi generate-client --nxBail",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "lib:ai": "yarn workspace @multiplier/lib-platform-ai",
    "lib:billing": "yarn workspace @multiplier/lib-platform-billing",
    "lib:business-analysis": "yarn workspace @multiplier/lib-platform-business-analysis",
    "lib:business-configuration": "yarn workspace @multiplier/lib-platform-business-configuration",
    "lib:credentials": "yarn workspace @multiplier/lib-shared-credentials",
    "lib:data-acquisition": "yarn workspace @multiplier/lib-platform-data-acquisition",
    "lib:email-client": "yarn workspace @multiplier/lib-shared-email-client",
    "lib:email-templates": "yarn workspace @multiplier/lib-shared-email-templates",
    "lib:fastify": "yarn workspace @multiplier/lib-shared-fastify",
    "lib:feature-flags": "yarn workspace @multiplier/lib-shared-feature-flags",
    "lib:kip-contracts": "yarn workspace @multiplier/lib-kip-contracts",
    "lib:kip-knowledge-intelligence": "yarn workspace @multiplier/lib-kip-knowledge-intelligence",
    "lib:organization-management": "yarn workspace @multiplier/lib-platform-organization-management",
    "lib:postgres": "yarn workspace @multiplier/lib-shared-postgres",
    "lib:scripts": "yarn workspace @multiplier/lib-shared-scripts",
    "lib:storage": "yarn workspace @multiplier/lib-platform-storage",
    "lib:stripe-client": "yarn workspace @multiplier/lib-shared-stripe-client",
    "lib:testing": "yarn workspace @multiplier/lib-shared-testing",
    "lib:tax-warden": "yarn workspace @multiplier/lib-tax-warden",
    "lib:types": "yarn workspace @multiplier/lib-shared-types",
    "lib:xero-client": "yarn workspace @multiplier/lib-shared-xero-client",
    "lint": "yarn run lint:biome && yarn run lint:eslint",
    "lint:biome": "yarn exec biome check . --max-diagnostics=50 --error-on-warnings",
    "lint:biome:staged": "yarn exec biome check --staged --no-errors-on-unmatched --max-diagnostics=50 --error-on-warnings",
    "lint:eslint": "eslint . --cache --cache-strategy content",
    "lint:fix": "eslint . --fix --cache --cache-strategy content && yarn exec biome check . --write",
    "mock-auth": "yarn run -T dotenvx run --ignore=MISSING_ENV_FILE --overload -f .env -f scripts/dev/.env -- tsx scripts/dev/mock-auth/mock-auth-server.ts",
    "mock-flags": "yarn run -T dotenvx run --ignore=MISSING_ENV_FILE --overload -f .env -f scripts/dev/.env -- tsx scripts/dev/mock-flags/mock-flags-server.ts",
    "prepare": "husky",
    "run:corp:dev": "yarn run -T concurrently \"yarn app:corporate:api dev\" \"yarn app:platform dev\" \"yarn app:corporate:frontend dev\" \"yarn app:webhooks dev\" \"yarn app:corporate:dataservice dev\"",
    "nxtest": "tsx scripts/nxtest.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "validate": "yarn validate:affected-target-detector && yarn validate:cloudbuild-release-tags && yarn validate:cloudbuild-substitutions && yarn validate:cloudbuild-helm-deploy && yarn validate:cloud-run-deploy-flags && yarn validate:information-search-observability && yarn validate:workspace-locations && yarn validate:skills-yaml && yarn validate:vitest-configs && yarn validate:project-tags",
    "validate:affected-target-detector": "./scripts/ci/detect-affected-target.test.sh",
    "validate:vitest-configs": "./scripts/validate-vitest-configs.sh",
    "validate:project-tags": "./scripts/ci/validate-project-tags.sh",
    "validate:cloudbuild-release-tags": "./scripts/ci/validate-cloudbuild-release-tags.sh",
    "validate:cloudbuild-substitutions": "./scripts/ci/validate-cloudbuild-substitutions.sh",
    "validate:cloudbuild-helm-deploy": "./scripts/ci/validate-cloudbuild-helm-deploy.sh",
    "validate:cloud-run-deploy-flags": "./scripts/ci/validate-cloud-run-deploy-flags.sh",
    "validate:information-search-observability": "./scripts/ci/validate-information-search-observability.sh",
    "validate:workspace-locations": "./scripts/ci/validate-workspace-locations.sh",
    "validate:helm-renders": "./scripts/ci/validate-helm-renders.sh",
    "validate:skills-yaml": "./scripts/ci/validate-skills-yaml.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@dotenvx/dotenvx": "^1.48.3",
    "@eslint/plugin-kit": "^0.3.4",
